const SUPABASE_URL = "https://adclnjzcimqktzilvldp.supabase.co";

const SUPABASE_KEY = "TU_KEY_AQUI";

console.log("SUPABASE CARGADO");

const db = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);



// =======================
// PROGRESO
// =======================

async function guardarProgreso(uid, juego, nivel, puntos) {

    console.log("GUARDANDO EN SUPABASE", {
        uid,
        juego,
        nivel,
        puntos
    });

    const { data, error } = await db
        .from("progreso")
        .upsert(
            [{
                uid,
                juego,
                nivel,
                puntos
            }],
            {
                // 🔴 FIX IMPORTANTE:
                // ahora incluye nivel para NO pisar otros niveles
                onConflict: "uid,juego,nivel"
            }
        )
        .select();

    if (error) {
        console.error("ERROR PROGRESO:", error);
        return false;
    }

    console.log("DATA:", data);

    return true;
}

window.guardarProgreso = guardarProgreso;



async function cargarProgresoSupabase(uid) {

    const { data, error } = await db
        .from("progreso")
        .select("*")
        .eq("uid", uid);

    if (error) {
        console.error("ERROR PROGRESO LOAD:", error);
        return [];
    }

    return data;
}

window.cargarProgresoSupabase = cargarProgresoSupabase;



// =======================
// USUARIOS
// =======================

async function guardarUsuario(usuario) {

    const { data, error } = await db
        .from("usuarios")
        .upsert([usuario])
        .select();

    if (error) {
        console.error("ERROR USUARIO:", error);
        return false;
    }

    return true;
}

window.guardarUsuario = guardarUsuario;



async function obtenerUsuario(email) {

    const { data, error } = await db
        .from("usuarios")
        .select("*")
        .eq("email", email)
        .single();

    if (error) {
        console.error("ERROR GET USER:", error);
        return null;
    }

    return data;
}

window.obtenerUsuario = obtenerUsuario;
